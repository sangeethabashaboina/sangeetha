<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>College Registration Form</title>

    <style>

    body{
        background:#f2f4ff;
        font-family:Arial;
        display:flex;
        justify-content:center;
        align-items:center;
        height:100vh;
    }

    .container{
        background:white;
        padding:25px;
        border-radius:10px;
        width:320px;
        box-shadow:0 0 10px lightgray;
    }

    h2{
        text-align:center;
        color:#4c63ff;
    }

    label{
        font-weight:bold;
    }

    input, select, textarea{
        width:100%;
        padding:8px;
        margin-top:5px;
        margin-bottom:10px;
        border:1px solid #ccc;
        border-radius:5px;
    }

    input[type="radio"]{
        width:auto;
    }

    input[type="submit"]{
        background:#4c63ff;
        color:white;
        border:none;
        cursor:pointer;
        font-size:16px;
    }

    input[type="submit"]:hover{
        background:#3248d1;
    }

    </style>

</head>

<body>

    <div class="container">

    <h2>College Registration Form</h2>

    <form>

        <label>Full Name:</label><br>
        <input type="text" placeholder="Enter your name"><br>

        <label>Email:</label><br>
        <input type="email" placeholder="Enter your email"><br>

        <label>Phone Number:</label><br>
        <input type="tel" placeholder="Enter phone number"><br>

        <label>Gender:</label><br>
        <input type="radio" name="gender"> Male
        <input type="radio" name="gender"> Female<br><br>

        <label>Course:</label><br>
        <select>
            <option>B.Tech</option>
            <option>B.Sc</option>
            <option>B.Com</option>
            <option>BBA</option>
        </select><br>

        <label>Address:</label><br>
        <textarea rows="4"></textarea><br>

        <input type="submit" value="Register">

    </form>

    </div>

</body>
</html>
