<!DOCTYPE html>
<html>
<head>
    <title>Simple Navigation Bar</title>

    <style>
        body{
            margin: 0;
            font-family: Arial, sans-serif;
        }

        nav{
            background-color: #333;
            padding: 15px;
        }

        nav a{
            color: white;
            text-decoration: none;
            margin: 15px;
            font-size: 18px;
        }

        nav a:hover{
            color: yellow;
        }
    </style>
</head>

<body>

    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Services</a>
        <a href="#">Contact</a>
    </nav>

</body>
</html>
